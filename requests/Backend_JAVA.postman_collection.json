        {
            "name": "REST API - Fluxo Completo (USER vs ADMIN)",
            "item": [
                {
                    "name": "0. Autenticação",
                    "item": [
                        {
                            "name": "Registrar Novo Usuário (Sempre USER)",
                            "event": [
                                {
                                    "listen": "test",
                                    "script": {
                                        "exec": [
                                            "if (pm.response.code === 200) {",
                                            "    var jsonData = pm.response.json();",
                                            "    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
                                            "}"
                                        ],
                                        "type": "text/javascript"
                                    }
                                }
                            ],
                            "request": {
                                "method": "POST",
                                "header": [],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"email\": \"cliente@teste.com\",\n    \"password\": \"senha123\",\n    \"firstName\": \"João\",\n    \"lastName\": \"Silva\",\n    \"address\": \"Rua das Flores, 123\",\n    \"gender\": \"Masculino\"\n}",
                                    "options": {
                                        "raw": {
                                            "language": "json"
                                        }
                                    }
                                },
                                "url": {
                                    "raw": "http://{{host}}:{{port}}/auth/register",
                                    "protocol": "http",
                                    "host": [
                                        "{{host}}"
                                    ],
                                    "port": "{{port}}",
                                    "path": [
                                        "auth",
                                        "register"
